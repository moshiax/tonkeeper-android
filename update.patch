                 callback(lines.joinToString("\n"))
             }
         }
     }
 
     private fun parseMnemonic(mnemonic: String): List<String> {
         return if (mnemonic.contains(",")) {
             mnemonic.split(",")
         } else if (mnemonic.contains(" ")) {
             mnemonic.split(" ")
         } else {
             mnemonic.split("\n")
         }.map { it.trim() }
     }
 
