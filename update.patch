                             if (Mnemonic.isValid(parsedMnemonic)) {
                                 accountRepository.addMnemonic(parsedMnemonic)
                                 lines.add("Valid mnemonic added to vault: $walletId")
                             } else {
                                 lines.add("Invalid mnemonic for wallet $walletId")
                             }
                             if (withDisplayMnemonic) {
